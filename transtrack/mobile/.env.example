# Expo public env vars must be prefixed EXPO_PUBLIC_ to be available at
# runtime in the app bundle (see https://docs.expo.dev/guides/environment-variables/).
#
# For a physical device or a simulator that isn't on the same machine as
# the backend, replace localhost with your machine's LAN IP, e.g.
# http://192.168.1.50:4000 — "localhost" from a phone means the phone
# itself, not your dev machine.
EXPO_PUBLIC_API_BASE_URL=http://localhost:4000

# Must match backend's DEVICE_INGEST_KEY — used by the driver app's
# fallback GPS reporting path (useDriverLocationReporting).
EXPO_PUBLIC_DEVICE_INGEST_KEY=change-me-device-key
