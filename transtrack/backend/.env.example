NODE_ENV=development
PORT=4000

# Postgres connection string (must have PostGIS extension available)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/transtrack

# Redis connection string
REDIS_URL=redis://localhost:6379

# JWT secrets — generate strong random values for real deployment, e.g.:
#   openssl rand -hex 32
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

# Shared key GPS devices (and the simulator) use to authenticate to /tracking/ingest
DEVICE_INGEST_KEY=change-me-device-key

# Comma-separated list of allowed web origins
CORS_ORIGINS=http://localhost:5173
