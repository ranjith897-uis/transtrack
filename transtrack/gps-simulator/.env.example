API_BASE_URL=http://localhost:4000
DEVICE_INGEST_KEY=change-me-device-key
DEVICE_EXTERNAL_ID=SIM-DEVICE-001

# Optional: pull real stop coordinates from a seeded route instead of the
# hardcoded fallback path. Get this id from `npm run db:seed` output, or
# from GET /routes after creating one via the admin console.
ROUTE_ID=

# Optional: only needed if ROUTE_ID is set — a valid admin/dispatcher
# access token, since GET /routes/:id requires authentication.
ADMIN_BEARER_TOKEN=

PING_INTERVAL_MS=3000
AVERAGE_SPEED_KMH=28
